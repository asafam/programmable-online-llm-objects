{
  "meta": {
    "lastTouchedVersion": "2026.3.23-2"
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": ["127.0.0.1", "::1", "172.16.0.0/12"]
  },
  "plugins": {
    "allow": ["lnl-mock-external"]
  },
  "tools": {
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "agents": {
    "defaults": {
      "model": "azure/gpt-5.4-mini",
      "llm": {
        "idleTimeoutSeconds": 300
      }
    },
    "list": []
  }
}
